DEBUG=1
SECRET_KEY=tu_clave_secreta
POSTGRES_DB=gymdb
POSTGRES_USER=gymuser
POSTGRES_PASSWORD=gympass
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=admin123

# Backup offsite (rclone): carpeta destino en el remoto, un subfolder por gym.
# Cada gym define la suya (ej. gdrive:gym-backups/cinaf, gdrive:gym-backups/gym2)
# y debe tener su propio rclone.conf en la raiz del proyecto (no se versiona, ver README).
RCLONE_REMOTE=gdrive:gym-backups/cinaf